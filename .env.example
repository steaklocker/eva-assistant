# ═══════════════════════════════════════════
# EVA — Executive Virtual Assistant
# Environment Configuration
# ═══════════════════════════════════════════

# Anthropic API Key (required)
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Supabase (required for persistence + learning)
# Get from: your Supabase project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxx

# Cron Secret (required for scheduled jobs — morning brief, monitoring)
# Generate any random string: openssl rand -hex 32
CRON_SECRET=your-random-secret-here

# ElevenLabs (optional — Phase 2 voice upgrade)
# ELEVENLABS_API_KEY=xxxxx
# ELEVENLABS_VOICE_ID=xxxxx
